{
  "name": "shopify-app-manager",
  "version": "0.1.0",
  "description": "CLI tool to scaffold and manage Shopify apps with React Router + Cloudflare Workers",
  "type": "module",
  "bin": {
    "sam": "./dist/index.js"
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "shopify",
    "cloudflare",
    "workers",
    "react-router",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@inquirer/prompts": "^7.0.0",
    "chalk": "^5.3.0",
    "commander": "^13.0.0",
    "execa": "^9.5.0",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0"
  }
}
